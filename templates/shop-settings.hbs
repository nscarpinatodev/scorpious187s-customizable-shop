{{!-- World shop settings --}}
<div class="scs-config-form">

  <div class="scs-config-section scs-grid2">
    <div class="scs-field">
      <label>{{localize "SCS.Settings.CurrencySystem"}}</label>
      <select name="currencyPreset">
        {{#each currencyPresets as |p|}}
          <option value="{{p.id}}" {{#if (scs-eq p.id ../currencyPreset)}}selected{{/if}}>{{p.label}}</option>
        {{/each}}
      </select>
      <p class="scs-hint">{{localize "SCS.Settings.CurrencyHint"}}</p>
    </div>
    <div class="scs-field">
      <label>{{localize "SCS.Settings.Theme"}}</label>
      <select name="theme" {{#if themeLocked}}disabled{{/if}}>
        {{#each themeChoices as |label id|}}
          <option value="{{id}}" {{#if (scs-eq id ../theme)}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
      {{#if themeLocked}}
        <p class="scs-hint"><i class="fas fa-lock"></i> {{localize "SCS.Settings.ThemeControlledByQT"}}</p>
      {{else}}
        <a class="scs-link" data-action="openThemeEditor"><i class="fas fa-palette"></i> {{localize "SCS.Config.EditCustomTheme"}}</a>
      {{/if}}
    </div>
    <div class="scs-field">
      <label>{{localize "SCS.Settings.LayoutSide"}}</label>
      <select name="layoutSide">
        <option value="left" {{#if (scs-eq layoutSide "left")}}selected{{/if}}>{{localize "SCS.Settings.LayoutLeft"}}</option>
        <option value="right" {{#if (scs-eq layoutSide "right")}}selected{{/if}}>{{localize "SCS.Settings.LayoutRight"}}</option>
      </select>
      <p class="scs-hint">{{localize "SCS.Settings.LayoutSideHint"}}</p>
    </div>
    <div class="scs-field">
      <label>{{localize "SCS.Settings.DefaultMarkup"}}</label>
      <input type="number" name="markup" value="{{markup}}" step="0.05" min="0">
    </div>
    <div class="scs-field">
      <label>{{localize "SCS.Settings.DefaultSellRate"}}</label>
      <input type="number" name="sellRate" value="{{sellRate}}" step="0.05" min="0">
    </div>
  </div>

  <div class="scs-config-section">
    <label class="scs-check">
      <input type="checkbox" name="adjustMerchantCurrency" {{checked adjustMerchantCurrency}}>
      <span>{{localize "SCS.Settings.AdjustMerchant"}}</span>
    </label>
    <p class="scs-hint">{{localize "SCS.Settings.AdjustMerchantHint"}}</p>
  </div>

  <footer class="scs-config-footer">
    <button type="submit"><i class="fas fa-save"></i> {{localize "SCS.Config.Save"}}</button>
  </footer>
</div>
